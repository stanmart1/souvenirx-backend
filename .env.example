# =============================================================================
# SouvenirX Backend - Environment Variables
# Copy this file to .env and fill in the values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL with async driver)
# -----------------------------------------------------------------------------
# Local development (no SSL)
DATABASE_URL=postgresql+asyncpg://souvenirx:your_secure_password@localhost:5432/souvenirx

# Production with SSL (recommended)
# Use one of these SSL modes based on your database provider's requirements:
# - sslmode=require: Require SSL but don't verify certificates (most common)
# - sslmode=verify-ca: Require SSL and verify CA certificate
# - sslmode=verify-full: Require SSL and verify hostname (most secure)
# DATABASE_URL=postgresql+asyncpg://souvenirx:your_secure_password@your-db-host:5432/souvenirx?sslmode=require

# -----------------------------------------------------------------------------
# Redis (used for rate limiting, caching, and the ARQ task queue)
# -----------------------------------------------------------------------------
# Local development (no SSL)
REDIS_URL=redis://localhost:6379/0

# Production with SSL — use the rediss:// scheme (note the extra 's').
# REDIS_URL=rediss://your-redis-host:6380/0

# ---------------------------------------------------------------------------
# Redis SSL certificate verification
# ---------------------------------------------------------------------------
# Options: "required" (default), "optional", "none"
#
#   "required" — Verify the server certificate against a trusted CA.
#                Use this with a CA-signed certificate (most secure).
#
#   "optional" — Verify if a CA bundle is available, accept otherwise.
#
#   "none"     — Disable certificate verification entirely.
#                Use this when Redis uses a SELF-SIGNED certificate and you
#                cannot (or do not want to) provide the CA bundle.
#                REQUIRED for deployments like Coolify that provision Redis
#                with a self-signed cert (e.g. rediss://host:5439/0).
#
# REDIS_SSL_CERT_REQS=none

# Path to the CA certificate (PEM) that signed the Redis server's cert.
# Only needed when REDIS_SSL_CERT_REQS=required and the CA is not in the
# system trust store (e.g. a private/internal CA).
# REDIS_SSL_CA_CERTS=/path/to/ca-cert.pem

# Client certificate and key for mutual TLS (mTLS) — only needed if Redis
# is configured to require client authentication.
# REDIS_SSL_CERTFILE=/path/to/client-cert.pem
# REDIS_SSL_KEYFILE=/path/to/client-key.pem

# -----------------------------------------------------------------------------
# Authentication (JWT)
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
# -----------------------------------------------------------------------------
JWT_SECRET=your_secure_random_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Payment Gateway - Paystack
# Use live keys in production, test keys in development
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Payment Gateway - Flutterwave
# Use live keys in production, test keys in development
# -----------------------------------------------------------------------------
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
# Webhook verification hash — set the same value in
# Flutterwave Dashboard > Settings > Webhooks as your "Verification Hash"
FLUTTERWAVE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=SouvenirX <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Application URLs
# Use your production domain in production
# -----------------------------------------------------------------------------
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com
UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# Firebase / FCM Push Notifications
# -----------------------------------------------------------------------------
# Path to the Firebase Admin SDK service account JSON file
# Download from Firebase Console > Project Settings > Service Accounts
# Copy app/config/firebase-credentials.json.example to firebase-credentials.json
# and fill in your actual credentials
FIREBASE_CREDENTIALS_PATH=app/config/firebase-credentials.json
